  "defaultContent": "<!--\nProblem: <PROBLEM_NAME>\nDifficulty: <DIFFICULTY>\nURL: <PROBLEM_URL>\nDate: <DATE>\nLanguage: <LANGUAGE>\n-->\n\n<SOLUTION_CODE>"
